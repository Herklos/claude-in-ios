{
  "name": "claude-ios",
  "version": "0.1.0",
  "description": "Serve iOS Simulator as a webpage + MCP bridge for Claude browser tools",
  "type": "module",
  "bin": {
    "claude-ios-simulator": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:web": "vite build",
    "dev:web": "vite",
    "dev": "npm run build:web && tsx src/cli.ts",
    "mcp": "tsx src/cli.ts mcp",
    "doctor": "tsx src/cli.ts doctor",
    "setup": "tsx src/cli.ts setup",
    "start": "node dist/cli.js",
    "link": "npm run build && npm link"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "execa": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
